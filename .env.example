# Anthropic — used for Haiku scoring and Playwright extraction
ANTHROPIC_API_KEY=

# Gmail API — used for sending the digest email
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_FROM=your@gmail.com
GMAIL_TO=your@gmail.com

# Optional: URL where digest.html is hosted (shown in email footer)
DIGEST_URL=

# Optional: live Vercel dashboard URL (shown in email footer)
VERCEL_URL=

# SQLite tracker database location
DB_PATH=~/job-digest/tracker.db

# Timezone for scheduler
TZ=America/Los_Angeles

# Optional: reuse an existing Google OAuth refresh-token flow instead of token.json
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
